OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-5.4-mini
OPENAI_ENABLE_WEB_SEARCH=true
NEXT_PUBLIC_SITE_URL=https://deeptechly.vercel.app

# Optional persistent research storage for Vercel.
# Use these from Upstash Redis or Vercel KV to persist jobs/articles across serverless invocations.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel KV names are also supported:
KV_REST_API_URL=
KV_REST_API_TOKEN=
