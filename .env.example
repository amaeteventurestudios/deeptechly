OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-5.4-mini
OPENAI_ENABLE_WEB_SEARCH=true
NEXT_PUBLIC_SITE_URL=https://deeptechly.vercel.app

# Supabase persistent research storage.
# Run supabase/research-store.sql once, then set these on Vercel.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=
DEEPTECHLY_BOOTSTRAP_ADMIN_EMAIL=
DEEPTECHLY_BOOTSTRAP_ADMIN_TEMP_PASSWORD=
# Optional override; defaults to deeptechly_research_store.
SUPABASE_RESEARCH_STORE_TABLE=deeptechly_research_store

# Optional persistent research storage for Vercel.
# Supabase is preferred. Upstash Redis or Vercel KV remain supported as fallback.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel KV names are also supported:
KV_REST_API_URL=
KV_REST_API_TOKEN=
